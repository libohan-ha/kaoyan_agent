# ===== DeepSeek（对话 + 意图识别 + Function Calling）=====
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== 硅基流动（Embedding）=====
SILICONFLOW_API_KEY=your_siliconflow_api_key
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3
SILICONFLOW_EMBEDDING_URL=https://api.siliconflow.cn/v1/embeddings
SILICONFLOW_EMBEDDING_TIMEOUT=30

# ===== 检索参数 =====
SEARCH_DEFAULT_TOP_K=8
EMBEDDING_DIM=1024

# ===== 服务 =====
HOST=127.0.0.1
PORT=8000

# ===== 每日复盘推送（APScheduler）=====
# 触发时间（24小时制），格式 HH:MM
REVIEW_PUSH_TIME=07:30
# 推送通道：console（默认，打印日志） / weclaw
NOTIFIER_CHANNEL=console

# ===== WeClaw 推送（可选，后面配）=====
# WeClaw 的主动推送 HTTP 接口地址（部署好 WeClaw 后填）
WECLAW_PUSH_URL=
# WeClaw 推送 token（如有）
WECLAW_PUSH_TOKEN=
